{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "ES2020"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": ".tmp-tests",
    "types": []
  },
  "include": ["src/lib/**/*.ts", "src/types.ts", "src/types/chrome.d.ts", "tests/**/*.ts"]
}
